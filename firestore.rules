rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validLoanSettings(m) {
      return m is map
        && m.keys().hasOnly(['minLimit', 'maxLimit', 'selectedAmount'])
        && m.minLimit is number
        && m.maxLimit is number
        && m.selectedAmount is number;
    }

    function userDocumentShape() {
      let u = request.resource.data;
      return u.keys().hasAll([
          'name', 'phone', 'role', 'isBlocked',
          'createdAt', 'updatedAt', 'loanSettings'
        ])
        && u.name is string
        && u.phone is string
        && u.role is string
        && u.role in ['admin', 'user']
        && u.isBlocked is bool
        && u.createdAt is timestamp
        && u.updatedAt is timestamp
        && u.loanSettings is map
        && validLoanSettings(u.loanSettings);
    }

    function userSelfUpdateValid() {
      let after = request.resource.data;
      let before = resource.data;
      return userDocumentShape()
        && after.role == before.role
        && after.phone == before.phone
        && after.isBlocked == before.isBlocked
        && after.createdAt == before.createdAt;
    }

    function orderDocumentShape() {
      let o = request.resource.data;
      return o.keys().hasAll([
          'userId', 'userName', 'phone',
          'loanAmount', 'totalDueAmount',
          'loanDate', 'dueDate',
          'createdAt', 'updatedAt',
          'paymentUrl', 'isCompleted'
        ])
        && o.userId is string
        && o.userName is string
        && o.phone is string
        && o.loanAmount is number
        && o.totalDueAmount is number
        && o.loanDate is timestamp
        && o.dueDate is timestamp
        && o.createdAt is timestamp
        && o.updatedAt is timestamp
        && o.paymentUrl is string
        && o.isCompleted is bool;
    }

    function adminSettingsShape() {
      let s = request.resource.data;
      return s.keys().hasAll(['minLimit', 'maxLimit', 'updatedAt'])
        && s.minLimit is number
        && s.maxLimit is number
        && s.updatedAt is timestamp
        && (!('defaultInterestRate' in s) || s.defaultInterestRate is number);
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);

      allow create: if (isAdmin() && userDocumentShape())
        || (
          isOwner(userId)
          && userDocumentShape()
          && request.resource.data.role == 'user'
          && request.resource.data.isBlocked == false
        );

      allow update: if (isAdmin() && userDocumentShape())
        || (isOwner(userId) && userSelfUpdateValid());

      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);

      allow create: if isAdmin() && orderDocumentShape();

      allow update: if isAdmin() && orderDocumentShape();

      allow delete: if isAdmin();
    }

    match /blocked_users/{docId} {
      allow read, write: if isAdmin();
    }

    match /admin_settings/{docId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && adminSettingsShape();
      allow delete: if isAdmin();
    }
  }
}
